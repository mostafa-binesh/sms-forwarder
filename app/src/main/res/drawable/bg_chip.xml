<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Rounded rectangle -->
    <corners
        android:radius="20dp" />

    <!-- Banking-green chip background -->
    <solid
        android:color="#E8F5E9" />

    <!-- Subtle border -->
    <stroke
        android:width="1dp"
        android:color="#A5D6A7" />

    <!-- Internal padding -->
    <padding
        android:left="12dp"
        android:top="6dp"
        android:right="12dp"
        android:bottom="6dp" />

</shape>
